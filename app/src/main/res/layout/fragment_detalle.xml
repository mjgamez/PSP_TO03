<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tvDetalleTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nombre de la Estación"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#D32F2F"
        android:layout_marginBottom="20dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvDetalleBicis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bicicletas disponibles: --"
                android:textSize="18sp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvDetalleAnclajes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Anclajes disponibles: --"
                android:textSize="18sp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvDetalleEstado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estado: --"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvDetalleActualizacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Última actualización: --"
                android:textSize="16sp"
                android:textColor="#888888"
                android:paddingBottom="8dp" />


        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
