<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">


    <!-- bias indica el porcentaje de separación -->


    <TextView
        android:id="@+id/tvopcion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Elige una opción"
        android:textSize="32sp"
        android:textColor="#000000"
        app:layout_constraintVertical_bias="0.10"
        app:layout_constraintTop_toTopOf="parent"
        android:padding="30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnEj2"
        android:text="Ejercicio 2"
        android:textSize="22dp"
        android:layout_width="200dp"
        android:layout_height="70dp"
        app:layout_constraintVertical_bias="0.10"
        app:layout_constraintTop_toBottomOf="@+id/tvopcion"
        android:padding="15dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />


    <Button
        android:id="@+id/btnEj3"
        android:text="Ejercicio 3"
        android:textSize="22dp"
        android:layout_width="200dp"
        android:layout_height="70dp"
        app:layout_constraintVertical_bias="0.10"
        app:layout_constraintTop_toBottomOf="@+id/btnEj2"
        android:padding="15dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>





</androidx.constraintlayout.widget.ConstraintLayout>